# ============================================
# AI4Community Backend - Environment Variables
# ============================================
# Copy this file to .env and fill in your values.
# On Render, set these as Environment Variables in the dashboard.

# Google Gemini API key (required)
# Get one from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Frontend URL for CORS (set to your deployed frontend URL)
FRONTEND_URL=https://your-frontend.vercel.app

# SMTP Settings for OTP Email Validation
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# JWT Secret Key
JWT_SECRET=generate_a_random_secret_string_here
